// 俱乐部课时系统 - 数据库 Schema
// 使用 SQLite 开发，生产环境切换到 PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            Int       @id @default(autoincrement())
  phone         String    @unique // 手机号
  name          String    // 姓名
  avatar        String?   // 头像URL
  gender        Int?      // 性别：0未知 1男 2女
  birthDate     DateTime? // 出生日期
  passwordHash  String?   // 密码哈希
  role          String    // 角色：super_admin/club_admin/coach
  status        Int       @default(1) // 状态：0禁用 1启用
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  adminClubs    Club[]    @relation("ClubAdmin")
  coachCourses  Course[]  @relation("CourseCoach")
  createdCourses Course[] @relation("CourseCreator")
  coachLessons  Lesson[]  @relation("LessonCoach")
  lessonsConfirmed Lesson[] @relation("LessonConfirmer")
  memberships   ClubMember[]
  coachPrices   CoachPrice[]
  coachStudents Student[]    @relation("CoachStudents")
}

// 俱乐部表
model Club {
  id            Int       @id @default(autoincrement())
  name          String    // 俱乐部名称
  description   String?   // 俱乐部简介
  logo          String?   // Logo URL
  coverImage    String?   // 封面图URL
  phone         String?   // 联系电话
  address       String?   // 总部地址
  businessHours String?   // 营业时间
  adminId       Int       // 管理员ID
  status        Int       @default(1) // 状态：0禁用 1启用
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  admin         User      @relation("ClubAdmin", fields: [adminId], references: [id])
  campuses      Campus[]
  subjects      Subject[]
  courses       Course[]
  settlements   Settlement[]
  members       ClubMember[]
  coachPrices   CoachPrice[]
  students      Student[]
}

// 校区表
model Campus {
  id            Int       @id @default(autoincrement())
  clubId        Int       // 所属俱乐部
  name          String    // 校区名称
  address       String    // 校区地址
  phone         String?   // 联系电话
  businessHours String?   // 营业时间
  status        Int       @default(1) // 状态：0禁用 1启用
  createdAt     DateTime  @default(now())

  // 关联
  club          Club      @relation(fields: [clubId], references: [id])
  courses       Course[]

  @@index([clubId])
}

// 俱乐部成员表（多对多）
model ClubMember {
  id        Int      @id @default(autoincrement())
  clubId    Int
  userId    Int
  role      String   // 角色：admin/coach
  joinedAt  DateTime @default(now())

  // 关联
  club      Club     @relation(fields: [clubId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([clubId, userId])
}

// 科目表
model Subject {
  id              Int      @id @default(autoincrement())
  clubId          Int      // 所属俱乐部
  name            String   // 科目名称
  category        String?  // 分类：篮球/足球/钢琴等
  teachingMode    String   // 授课方式：private/group
  durationMinutes Int      @default(60) // 标准课时长度(分钟)
  price           Decimal  // 标准课时单价
  description     String?  // 科目描述
  status          Int      @default(1) // 状态：0禁用 1启用
  createdAt       DateTime @default(now())

  // 关联
  club            Club     @relation(fields: [clubId], references: [id])
  courses         Course[]
  settlementItems SettlementItem[]
  coachPrices     CoachPrice[]

  @@index([clubId])
}

// 教练定价表（俱乐部+教练+科目+授课模式 = 价格）
model CoachPrice {
  id            Int      @id @default(autoincrement())
  clubId        Int      // 俱乐部ID
  coachId       Int      // 教练ID
  subjectId     Int      // 科目ID
  teachingMode  String   // 授课方式：private=一对一, duo=一对二, group=一对多
  price         Decimal  // 课时单价(元)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  club          Club     @relation(fields: [clubId], references: [id])
  coach         User     @relation(fields: [coachId], references: [id])
  subject       Subject  @relation(fields: [subjectId], references: [id])

  @@unique([clubId, coachId, subjectId, teachingMode])
  @@index([clubId])
  @@index([coachId])
  @@index([subjectId])
}

// 课程表（排课）
model Course {
  id             Int      @id @default(autoincrement())
  clubId         Int
  campusId       Int?     // 校区ID，支持多校区
  subjectId      Int
  coachId        Int      // 教练ID
  teachingMode   String   // 授课方式：private/group
  scheduledDate  DateTime // 上课日期
  startTime      String   // 开始时间
  endTime        String   // 结束时间
  location       String?  // 上课地点（具体教室/场地）
  status         String   @default("scheduled") // 状态：scheduled/in_progress/completed/cancelled
  remark         String?  // 备注
  createdBy      Int      // 创建人
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // 关联
  club           Club     @relation(fields: [clubId], references: [id])
  campus         Campus?  @relation(fields: [campusId], references: [id])
  subject        Subject  @relation(fields: [subjectId], references: [id])
  coach          User     @relation("CourseCoach", fields: [coachId], references: [id])
  creator        User     @relation("CourseCreator", fields: [createdBy], references: [id])
  students       CourseStudent[]
  lessons        Lesson[]

  @@index([coachId, scheduledDate, startTime])
  @@index([clubId, scheduledDate])
  @@index([campusId, scheduledDate])
}

// 课程学生关联表（多对多）
model CourseStudent {
  id        Int    @id @default(autoincrement())
  courseId   Int
  studentId Int

  // 关联
  course    Course @relation(fields: [courseId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
}

// 学员表（仅录入，学员不使用系统）
model Student {
  id        Int      @id @default(autoincrement())
  clubId    Int      // 所属俱乐部
  coachId   Int?     // 私有教练ID，null=俱乐部共享，有值=仅该教练可见
  name      String   // 姓名
  phone     String?  // 联系电话
  gender    Int?     // 性别：0未知 1男 2女
  birthDate DateTime? // 出生日期
  parentName String?  // 家长姓名
  parentPhone String? // 家长电话
  remark    String?  // 备注
  status    Int      @default(1) // 状态：0禁用 1启用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  club            Club      @relation(fields: [clubId], references: [id])
  coach           User?     @relation("CoachStudents", fields: [coachId], references: [id])
  courses         CourseStudent[]
  lessons         Lesson[]
  settlementItems SettlementItem[]

  @@index([clubId])
  @@index([coachId])
}

// 课时记录表
model Lesson {
  id             Int      @id @default(autoincrement())
  courseId        Int      // 关联课程
  studentId      Int      // 学生ID
  coachId        Int      // 教练ID
  actualStart    DateTime? // 实际开始时间
  actualEnd      DateTime? // 实际结束时间
  durationMinutes Int?    // 实际时长(分钟)
  content        String?  // 课程内容
  performance    String?  // 学生表现
  homework       String?  // 课后作业
  status         String   @default("pending") // 状态：pending/confirmed/cancelled
  confirmedAt    DateTime? // 确认时间
  confirmedById  Int?     // 确认人
  createdAt      DateTime @default(now())

  // 关联
  course         Course   @relation(fields: [courseId], references: [id])
  student        Student  @relation(fields: [studentId], references: [id])
  coach          User     @relation("LessonCoach", fields: [coachId], references: [id])
  confirmer      User?    @relation("LessonConfirmer", fields: [confirmedById], references: [id])
  settlementItems SettlementItem[]

  @@index([studentId, createdAt])
  @@index([coachId, createdAt])
}

// 费用结算表
model Settlement {
  id            Int      @id @default(autoincrement())
  clubId        Int
  coachId       Int
  periodStart   DateTime // 结算周期开始
  periodEnd     DateTime // 结算周期结束
  totalLessons  Int      // 总课时数
  totalMinutes  Int      // 总时长(分钟)
  totalAmount   Decimal  // 总结算金额
  status        String   @default("pending") // 状态：pending/paid/cancelled
  paidAt        DateTime? // 支付时间
  paidAmount    Decimal? // 实付金额
  remark        String?
  createdAt     DateTime @default(now())

  // 关联
  club          Club     @relation(fields: [clubId], references: [id])
  items         SettlementItem[]

  @@index([coachId, periodStart])
}

// 结算明细表
model SettlementItem {
  id            Int      @id @default(autoincrement())
  settlementId  Int
  lessonId      Int
  studentId     Int
  subjectId     Int
  durationMinutes Int    // 时长(分钟)
  unitPrice     Decimal  // 单价
  amount        Decimal  // 金额

  // 关联
  settlement    Settlement @relation(fields: [settlementId], references: [id])
  lesson        Lesson     @relation(fields: [lessonId], references: [id])
  student       Student    @relation(fields: [studentId], references: [id])
  subject       Subject    @relation(fields: [subjectId], references: [id])

  @@index([settlementId])
}
