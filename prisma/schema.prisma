generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               Int            @id @default(autoincrement())
  phone            String         @unique
  name             String
  avatar           String?
  gender           Int?
  birthDate        DateTime?
  passwordHash     String?
  role             String
  status           Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sentBookings     Booking[]      @relation("BookingUser")
  coachBookings    Booking[]      @relation("BookingCoach")
  adminClubs       Club[]         @relation("ClubAdmin")
  memberships      ClubMember[]
  coachPrices      CoachPrice[]
  createdCourses   Course[]       @relation("CourseCreator")
  coachCourses     Course[]       @relation("CourseCoach")
  repliedFeedbacks Feedback[]     @relation("FeedbackReplier")
  feedbacks        Feedback[]     @relation("FeedbackUser")
  lessonsConfirmed Lesson[]       @relation("LessonConfirmer")
  coachLessons     Lesson[]       @relation("LessonCoach")
  notifications    Notification[]
  childStudents    Student[]      @relation("StudentParent")
  managedStudents  Student[]      @relation("StudentUser")
  coachStudents    Student[]      @relation("CoachStudents")
  subjectCoaches   Subject[]      @relation("SubjectCoach")
}

model Club {
  id            Int          @id @default(autoincrement())
  name          String
  description   String?
  logo          String?
  coverImage    String?
  phone         String?
  address       String?
  businessHours String?
  adminId       Int?
  status        Int          @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bookings      Booking[]
  campuses      Campus[]
  admin         User?        @relation("ClubAdmin", fields: [adminId], references: [id])
  members       ClubMember[]
  coachPrices   CoachPrice[]
  courses       Course[]
  settlements   Settlement[]
  students      Student[]
  subjects      Subject[]
}

model Campus {
  id            Int      @id @default(autoincrement())
  clubId        Int
  name          String
  address       String
  phone         String?
  businessHours String?
  status        Int      @default(1)
  createdAt     DateTime @default(now())
  club          Club     @relation(fields: [clubId], references: [id])
  courses       Course[]

  @@index([clubId])
}

model ClubMember {
  id       Int      @id @default(autoincrement())
  clubId   Int
  userId   Int
  role     String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  club     Club     @relation(fields: [clubId], references: [id])

  @@unique([clubId, userId])
}

model Subject {
  id              Int              @id @default(autoincrement())
  clubId          Int?
  coachId         Int?
  name            String
  category        String?
  teachingMode    String
  durationMinutes Int              @default(60)
  price           Decimal
  description     String?
  status          Int              @default(1)
  createdAt       DateTime         @default(now())
  bookings        Booking[]
  coachPrices     CoachPrice[]
  courses         Course[]
  settlementItems SettlementItem[]
  coach           User?            @relation("SubjectCoach", fields: [coachId], references: [id])
  club            Club?            @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@index([coachId])
}

model CoachPrice {
  id           Int      @id @default(autoincrement())
  clubId       Int
  coachId      Int
  subjectId    Int
  teachingMode String
  price        Decimal
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  subject      Subject  @relation(fields: [subjectId], references: [id])
  coach        User     @relation(fields: [coachId], references: [id])
  club         Club     @relation(fields: [clubId], references: [id])

  @@unique([clubId, coachId, subjectId, teachingMode])
  @@index([clubId])
  @@index([coachId])
  @@index([subjectId])
}

model Course {
  id            Int             @id @default(autoincrement())
  clubId        Int?
  campusId      Int?
  subjectId     Int
  coachId       Int
  teachingMode  String
  scheduledDate DateTime
  startTime     String
  endTime       String
  location      String?
  status        String          @default("scheduled")
  remark        String?
  createdBy     Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  creator       User            @relation("CourseCreator", fields: [createdBy], references: [id])
  coach         User            @relation("CourseCoach", fields: [coachId], references: [id])
  subject       Subject         @relation(fields: [subjectId], references: [id])
  campus        Campus?         @relation(fields: [campusId], references: [id])
  club          Club?           @relation(fields: [clubId], references: [id])
  students      CourseStudent[]
  lessons       Lesson[]

  @@index([coachId, scheduledDate, startTime])
  @@index([clubId, scheduledDate])
  @@index([campusId, scheduledDate])
}

model CourseStudent {
  id        Int     @id @default(autoincrement())
  courseId  Int
  studentId Int
  student   Student @relation(fields: [studentId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])

  @@unique([courseId, studentId])
}

model Student {
  id              Int              @id @default(autoincrement())
  clubId          Int?
  coachId         Int?
  userId          Int?
  parentId        Int?
  studentType     String           @default("adult")
  name            String
  phone           String?
  gender          Int?
  birthDate       DateTime?
  parentName      String?
  parentPhone     String?
  remark          String?
  status          Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bookings        Booking[]
  courses         CourseStudent[]
  lessons         Lesson[]
  settlementItems SettlementItem[]
  parent          User?            @relation("StudentParent", fields: [parentId], references: [id])
  user            User?            @relation("StudentUser", fields: [userId], references: [id])
  coach           User?            @relation("CoachStudents", fields: [coachId], references: [id])
  club            Club?            @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@index([coachId])
  @@index([userId])
  @@index([parentId])
}

model Lesson {
  id              Int              @id @default(autoincrement())
  courseId        Int
  studentId       Int
  coachId         Int
  actualStart     DateTime?
  actualEnd       DateTime?
  durationMinutes Int?
  content         String?
  performance     String?
  homework        String?
  status          String           @default("pending")
  confirmedAt     DateTime?
  confirmedById   Int?
  createdAt       DateTime         @default(now())
  confirmer       User?            @relation("LessonConfirmer", fields: [confirmedById], references: [id])
  coach           User             @relation("LessonCoach", fields: [coachId], references: [id])
  student         Student          @relation(fields: [studentId], references: [id])
  course          Course           @relation(fields: [courseId], references: [id])
  settlementItems SettlementItem[]

  @@index([studentId, createdAt])
  @@index([coachId, createdAt])
}

model Settlement {
  id           Int              @id @default(autoincrement())
  clubId       Int
  coachId      Int
  periodStart  DateTime
  periodEnd    DateTime
  totalLessons Int
  totalMinutes Int
  totalAmount  Decimal
  status       String           @default("pending")
  paidAt       DateTime?
  paidAmount   Decimal?
  remark       String?
  createdAt    DateTime         @default(now())
  club         Club             @relation(fields: [clubId], references: [id])
  items        SettlementItem[]

  @@index([coachId, periodStart])
}

model SettlementItem {
  id              Int        @id @default(autoincrement())
  settlementId    Int
  lessonId        Int
  studentId       Int
  subjectId       Int
  durationMinutes Int
  unitPrice       Decimal
  amount          Decimal
  subject         Subject    @relation(fields: [subjectId], references: [id])
  student         Student    @relation(fields: [studentId], references: [id])
  lesson          Lesson     @relation(fields: [lessonId], references: [id])
  settlement      Settlement @relation(fields: [settlementId], references: [id])

  @@index([settlementId])
}

model Feedback {
  id          Int       @id @default(autoincrement())
  userId      Int
  category    String
  title       String
  content     String
  status      String    @default("pending")
  reply       String?
  repliedAt   DateTime?
  repliedById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  repliedBy   User?     @relation("FeedbackReplier", fields: [repliedById], references: [id])
  user        User      @relation("FeedbackUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Booking {
  id           Int      @id @default(autoincrement())
  clubId       Int
  studentId    Int
  coachId      Int
  subjectId    Int?
  userId       Int
  date         DateTime
  startTime    String
  endTime      String
  status       String   @default("pending")
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  rejectReason String?
  user         User     @relation("BookingUser", fields: [userId], references: [id])
  subject      Subject? @relation(fields: [subjectId], references: [id])
  coach        User     @relation("BookingCoach", fields: [coachId], references: [id])
  student      Student  @relation(fields: [studentId], references: [id])
  club         Club     @relation(fields: [clubId], references: [id])

  @@index([clubId, date])
  @@index([coachId, date])
  @@index([studentId])
  @@index([status])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  content   String?
  relatedId Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
}
